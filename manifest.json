{
  "manifest_version": 3,
  "name": "AI Chat Extractor",
  "version": "1.0",
  "description": "Extract conversations from ChatGPT, Claude, Gemini, and other AI chat interfaces",
  "permissions": ["activeTab", "scripting", "downloads"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "host_permissions": [
    "https://chatgpt.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}
